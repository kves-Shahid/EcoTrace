@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EcoTrace - Empowering Environmental Missions</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <style>
        .navbar-nav .nav-link {
            transition: color 0.2s;
        }

            .navbar-nav .nav-link:hover {
                color: #198754 !important;
            }

        /* AI CHATBOX BOX STYLES */
        #aiChatBox {
            position: fixed;
            bottom: 85px;
            right: 20px;
            width: 350px;
            height: 480px;
            z-index: 2000; /* Higher z-index to stay above maps */
            display: flex;
            flex-direction: column;
            transition: all 0.3s ease-in-out;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            border-radius: 15px;
            background: white;
            border: none;
        }

        .chat-toggle-btn {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 55px;
            height: 55px;
            border-radius: 50%;
            z-index: 2001;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 15px rgba(25, 135, 84, 0.4);
            border: none;
        }

        #chatMessages {
            flex: 1;
            overflow-y: auto;
            padding: 15px;
            background-color: #f8f9fa;
            display: flex;
            flex-direction: column;
        }

        .msg-user {
            align-self: flex-end;
            background-color: #198754;
            color: white;
            padding: 8px 12px;
            border-radius: 15px 15px 0 15px;
            margin-bottom: 10px;
            max-width: 85%;
        }

        .msg-ai {
            align-self: flex-start;
            background-color: white;
            border: 1px solid #dee2e6;
            color: #333;
            padding: 8px 12px;
            border-radius: 15px 15px 15px 0;
            margin-bottom: 10px;
            max-width: 85%;
        }

        .notification-bell {
            position: relative;
        }

        .notification-badge {
            position: absolute;
            top: 0;
            right: 0;
            transform: translate(50%, -20%);
            font-size: 0.65rem;
        }

        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        main {
            flex: 1;
        }
        /* Removed restricted padding to allow full-width maps */
        footer {
            background-color: #1a1a1a;
            color: #fff;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-success fs-3" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-leaf-fill"></i> EcoTrace
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="Leaderboard"><i class="bi bi-trophy text-warning"></i> Leaderboard</a></li>
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item"><a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="ScanQR"><i class="bi bi-upc-scan text-success"></i> Scanner</a></li>
                            <li class="nav-item"><a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="MyMissions"><i class="bi bi-flag"></i> My Missions</a></li>
                            <li class="nav-item"><a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="Profile"><i class="bi bi-person-circle"></i> My Profile</a></li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item ms-2 me-3 d-flex align-items-center">
                                <a class="btn btn-warning rounded-pill fw-bold px-3 shadow-sm btn-sm" asp-controller="Donation" asp-action="Index">
                                    <i class="bi bi-heart-fill text-danger me-1"></i> Support Us
                                </a>
                            </li>
                            <li class="nav-item me-3">
                                <a class="nav-link text-dark notification-bell" asp-controller="Home" asp-action="Notifications">
                                    <i class="bi bi-bell-fill fs-5"></i>
                                    <span id="notifBadge" class="badge rounded-pill bg-danger notification-badge d-none">0</span>
                                </a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item me-2"><a class="btn btn-outline-danger btn-sm fw-bold px-3" asp-controller="Admin" asp-action="Dashboard">Admin Panel</a></li>
                            }
                            <li class="nav-item"><span class="navbar-text text-dark me-3">Hello, <strong>@User.Identity?.Name?.Split('@')[0]</strong>!</span></li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-dark rounded-pill px-3">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link text-dark fw-bold" asp-controller="Account" asp-action="Login">Login</a></li>
                            <li class="nav-item ms-2"><a class="btn btn-success btn-sm rounded-pill px-4 fw-bold" asp-controller="Account" asp-action="Register">Join Now</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    @if (SignInManager.IsSignedIn(User))
    {
        <button class="btn btn-success chat-toggle-btn shadow-lg" onclick="toggleChat()">
            <i class="bi bi-robot fs-3"></i>
        </button>

        <div id="aiChatBox" class="card d-none border-0 overflow-hidden">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center py-3">
                <h6 class="mb-0 fw-bold"><i class="bi bi-stars me-2"></i>EcoTrace AI Assistant</h6>
                <button type="button" class="btn-close btn-close-white" onclick="toggleChat()"></button>
            </div>
            <div id="chatMessages">
                <div class="text-center small text-muted mb-3">Welcome! How can I help?</div>
            </div>
            <div class="card-footer bg-white border-top-0 p-3">
                <div class="input-group">
                    <input type="text" id="aiUserInput" class="form-control border-0 bg-light" placeholder="Ask a question..." onkeypress="handleChatKey(event)">
                    <button class="btn btn-success" onclick="sendAiMessage()">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </div>
        </div>
    }

    <footer class="pt-5 pb-4 mt-5 bg-dark">
        <div class="container text-center text-muted">
            <p class="small mb-0">&copy; @DateTime.Now.Year EcoTrace. Built for a Greener Tomorrow.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    @if (SignInManager.IsSignedIn(User))
    {
        <script>
            // Notification & AI Logic (Same as before)
            async function checkNotifications() {
                try {
                    const res = await fetch('/Home/GetUnreadNotifications');
                    const data = await res.json();
                    const badge = document.getElementById('notifBadge');
                    if (data.count > 0) {
                        badge.innerText = data.count;
                        badge.classList.remove('d-none');
                    } else {
                        badge.classList.add('d-none');
                    }
                } catch (e) { }
            }
            setInterval(checkNotifications, 30000);
            document.addEventListener("DOMContentLoaded", checkNotifications);

            function toggleChat() { document.getElementById("aiChatBox").classList.toggle("d-none"); loadHistory(); }

            let historyLoaded = false;
            async function loadHistory() {
                if(historyLoaded) return;
                try {
                    const response = await fetch('/api/AiChat/history');
                    const data = await response.json();
                    data.forEach(msg => appendMessage(msg.text, msg.isAi));
                    historyLoaded = true;
                } catch (e) { }
            }

            function appendMessage(text, isAi) {
                const container = document.getElementById("chatMessages");
                container.insertAdjacentHTML('beforeend', `<div class="${isAi ? 'msg-ai' : 'msg-user'}">${text}</div>`);
                container.scrollTop = container.scrollHeight;
            }

            function handleChatKey(e) { if (e.key === 'Enter') sendAiMessage(); }

            async function sendAiMessage() {
                const input = document.getElementById("aiUserInput");
                const message = input.value.trim();
                const container = document.getElementById("chatMessages");
                if (!message) return;
                appendMessage(message, false);
                input.value = "";
                const loadingId = "loading-" + Date.now();
                container.insertAdjacentHTML('beforeend', `<div id="${loadingId}" class="text-start mb-3 small text-muted">Thinking...</div>`);
                try {
                    const response = await fetch('/api/AiChat/ask', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message: message })
                    });
                    const data = await response.json();
                    document.getElementById(loadingId).remove();
                    appendMessage(data.reply, true);
                } catch (error) { document.getElementById(loadingId).remove(); }
            }
        </script>
    }
    @RenderSection("Scripts", required: false)
</body>
</html>
@model EcoTraceApp.Models.Event
@{
    Layout = null; 
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #f0f2f5;
            padding: 50px;
        }

        .cert-container {
            border: 15px solid #198754;
            background: white;
            padding: 60px;
            position: relative;
            box-shadow: 0 0 50px rgba(0,0,0,0.1);
            max-width: 900px;
            margin: auto;
            text-align: center;
        }

        .cert-header {
            color: #198754;
            font-family: 'Georgia', serif;
            font-size: 3.5rem;
            font-weight: bold;
        }

        .cert-seal {
            width: 120px;
            margin-top: 30px;
            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.2));
        }

        .signature {
            font-family: 'Cursive', sans-serif;
            border-top: 2px solid #333;
            display: inline-block;
            padding-top: 10px;
            margin-top: 40px;
        }
    </style>
</head>
<body onload="window.print()">
    <div class="cert-container">
        <div class="cert-header">EcoTrace</div>
        <h2 class="text-uppercase mt-4" style="letter-spacing: 5px;">Certificate of Contribution</h2>
        <p class="mt-5 fs-4">This is to officially recognize</p>
        <h1 class="display-3 fw-bold text-dark my-4">@(ViewBag.UserEmail?.Split('@')[0] ?? "Our Hero")</h1>
        <p class="fs-4 px-5">
            For their exceptional dedication and volunteer service during the mission: <br />
            <strong class="text-success">@Model.Title</strong>
        </p>
        <p class="mt-4 text-muted">Completed on @Model.EventDate.ToString("MMMM dd, yyyy")</p>

        <img src="https://cdn-icons-png.flaticon.com/512/6065/6065103.png" class="cert-seal" alt="Eco Seal" />

        <div class="d-flex justify-content-around mt-5">
            <div class="text-center">
                <div class="signature px-4">Shahid, EcoTrace Admin</div>
                <p class="small text-muted">Mission Director</p>
            </div>
            <div class="text-center">
                <div class="signature px-4">@DateTime.Now.ToString("yyyy-MM-dd")</div>
                <p class="small text-muted">Issue Date</p>
            </div>
        </div>
    </div>
</body>
</html>
@model IEnumerable<EcoTraceApp.Models.Report>
@{
    ViewData["Title"] = "Moderation Center";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-shield-exclamation text-danger"></i> Moderation Center</h2>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm p-5 text-center" style="border-radius: 20px;">
            <i class="bi bi-check-circle text-success display-1 mb-3"></i>
            <h4 class="text-muted">All clear! No pending reports.</h4>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded-4">
            <table class="table table-hover align-middle bg-white mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Type</th>
                        <th>Reason</th>
                        <th>Reported At</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="badge @(report.TargetType == "Event" ? "bg-primary" : "bg-info text-dark")">
                                    @report.TargetType
                                </span>
                            </td>
                            <td>@report.Reason</td>
                            <td class="text-muted small">@report.CreatedAt.ToString("g")</td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <form asp-action="DismissReport" asp-route-id="@report.Id" method="post">
                                        <button class="btn btn-sm btn-outline-secondary">Dismiss</button>
                                    </form>
                                    <form asp-action="DeleteReportedTarget" method="post" onsubmit="return confirm('Permanently delete this item?');">
                                        <input type="hidden" name="id" value="@report.Id" />
                                        <input type="hidden" name="targetId" value="@report.TargetId" />
                                        <input type="hidden" name="targetType" value="@report.TargetType" />
                                        <button class="btn btn-sm btn-danger">Delete Content</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
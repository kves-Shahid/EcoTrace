@model IEnumerable<EcoTraceApp.Models.Event>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Admin Control Center</h2>
        <a asp-action="CreateEvent" class="btn btn-success px-4">+ Create New Event</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        @foreach (var item in Model.OrderByDescending(e => e.CreatedAt))
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0" style="border-radius: 20px; overflow: hidden; transition: 0.3s;">
                    <div style="height: 180px; background-color: #f0f0f0; position: relative;">
                        @if (!string.IsNullOrEmpty(item.MapUrl))
                        {
                            <iframe src="@item.MapUrl" width="100%" height="100%" style="border:0;" allowfullscreen=""></iframe>
                        }
                        else if (!string.IsNullOrEmpty(item.MediaFilePath))
                        {
                            <img src="@item.MediaFilePath" class="w-100 h-100" style="object-fit: cover;" />
                        }

                        <div class="position-absolute top-0 end-0 m-2">
                            @if (item.IsCompleted)
                            {
                                <span class="badge bg-success shadow-sm px-2 py-1"><i class="bi bi-check-circle-fill"></i> Completed</span>
                            }
                            else
                            {
                                <span class="badge bg-primary shadow-sm px-2 py-1"><i class="bi bi-play-circle-fill"></i> Active</span>
                            }
                        </div>
                    </div>

                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-success">@item.EventType</span>
                            <span class="text-muted small">@item.Registrations.Count Joined</span>
                        </div>
                        <h5 class="card-title fw-bold">@item.Title</h5>
                        <p class="text-muted small"><i class="bi bi-geo-alt"></i> @item.LocationName</p>

                        <div class="mt-auto">
                            <div class="d-flex gap-2 mt-3 mb-2">
                                <a asp-action="EditEvent" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm flex-fill fw-bold">Edit</a>
                                <a asp-action="EventVolunteers" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm flex-fill fw-bold">Users</a>
                                <form asp-action="DeleteEvent" asp-route-id="@item.Id" method="post" class="flex-fill" onsubmit="return confirm('Are you sure you want to completely delete this event?');">
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100 fw-bold">Delete</button>
                                </form>
                            </div>

                            @if (!item.IsCompleted)
                            {
                                <button type="button" class="btn btn-success btn-sm w-100 fw-bold" data-bs-toggle="modal" data-bs-target="#completeModal-@item.Id">
                                    <i class="bi bi-trophy-fill me-1"></i> Mark as Completed
                                </button>
                            }
                            else
                            {
                                <a asp-controller="Home" asp-action="Details" asp-route-id="@item.Id" class="btn btn-dark btn-sm w-100 fw-bold">
                                    <i class="bi bi-eye-fill me-1"></i> View Gallery & Page
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@foreach (var item in Model)
{
    if (!item.IsCompleted)
    {
        <div class="modal fade text-start" id="completeModal-@item.Id" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content" style="border-radius: 15px;">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold text-success"><i class="bi bi-trophy-fill me-2"></i> Complete Mission</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <form asp-action="CompleteEvent" method="post">
                        <div class="modal-body">
                            <input type="hidden" name="id" value="@item.Id" />
                            <p class="text-muted">You are about to officially close <strong>@item.Title</strong>. Please provide a short summary of the impact your volunteers made!</p>

                            <div class="mb-3">
                                <label class="fw-bold mb-2">Impact Summary</label>
                                <textarea name="impact" class="form-control bg-light" rows="3" placeholder="e.g., Planted 200 saplings and cleared 50kg of plastic waste..." required></textarea>
                            </div>
                        </div>
                        <div class="modal-footer border-0 pt-0">
                            <button type="button" class="btn btn-light" data-bs-dismiss="modal" style="border-radius: 8px;">Cancel</button>
                            <button type="submit" class="btn btn-success fw-bold" style="border-radius: 8px;">Submit Results</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}

<style>
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>
@model EcoTraceApp.Models.Event
@{
    ViewData["Title"] = "Mission Command Center";
    var pendingTasks = Model.Tasks.Where(t => t.IsPendingVerification).ToList();
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm mb-2"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
            <h2 class="fw-bold"><i class="bi bi-sliders text-primary"></i> Mission Control: @Model.Title</h2>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Home" asp-action="EventChat" asp-route-id="@Model.Id" class="btn btn-success fw-bold shadow-sm">
                <i class="bi bi-chat-text-fill me-1"></i> Live Chat
            </a>
            <a asp-controller="Home" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary fw-bold shadow-sm" target="_blank">
                <i class="bi bi-box-arrow-up-right me-1"></i> Public Page
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
                <div class="card-header bg-dark text-white fw-bold py-3">Edit Details</div>
                <div class="card-body bg-light">
                    <form asp-action="EditEvent" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatorId" />
                        <div class="mb-3">
                            <label class="fw-bold text-muted small">Event Title</label>
                            <input asp-for="Title" class="form-control border-0 shadow-sm" required />
                        </div>
                        <div class="mb-4">
                            <label class="fw-bold text-muted small">Cover Image</label>
                            <input type="file" name="mediaFile" class="form-control border-0 shadow-sm" />
                        </div>
                        <button type="submit" class="btn btn-warning w-100 fw-bold">Save Basic Changes</button>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm border-0" style="border-radius: 15px;">
                <div class="card-header bg-success text-white fw-bold py-3">Add New Task</div>
                <div class="card-body">
                    <form asp-action="AddTaskAdmin" method="post">
                        <input type="hidden" name="eventId" value="@Model.Id" />
                        <input type="text" name="title" class="form-control bg-light border-0 mb-3" placeholder="e.g., Bring 10 Shovels" required />
                        <button type="submit" class="btn btn-primary w-100 fw-bold">Add to Board</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            @if (pendingTasks.Any())
            {
                <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px; border-left: 5px solid #ffc107 !important;">
                    <div class="card-header bg-white fw-bold py-3 text-warning">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> Verification Queue
                    </div>
                    <div class="card-body">
                        @foreach (var pt in pendingTasks)
                        {
                            <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                                <div>
                                    <h6 class="fw-bold mb-0">@pt.Title</h6>
                                    <small class="text-muted">By: @pt.AssignedUser?.Email</small>
                                </div>
                                <div class="d-flex gap-2">
                                    <a href="@pt.ProofImagePath" target="_blank" class="btn btn-sm btn-outline-primary"><i class="bi bi-image"></i> View Proof</a>
                                    <form asp-action="VerifyTask" method="post">
                                        <input type="hidden" name="taskId" value="@pt.Id" />
                                        <button type="submit" class="btn btn-sm btn-success fw-bold">Verify & Reward</button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
                <div class="card-header bg-primary text-white fw-bold py-3 d-flex justify-content-between">
                    <span>Task Delegation</span>
                    <span class="badge bg-light text-primary">@Model.Tasks.Count Tasks</span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Task</th>
                                <th>Assign User</th>
                                <th class="text-end pe-4">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in Model.Tasks)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold">@task.Title</div>
                                        @if (task.IsVerified)
                                        {
                                            <span class="badge bg-success-subtle text-success">Verified</span>
                                        }
                                    </td>
                                    <td>
                                        <form asp-action="AssignTaskAdmin" method="post" class="m-0">
                                            <input type="hidden" name="taskId" value="@task.Id" />
                                            <input type="hidden" name="eventId" value="@Model.Id" />
                                            <select name="userId" class="form-select form-select-sm" onchange="this.form.submit()">
                                                <option value="">-- Open --</option>
                                                @foreach (var reg in Model.Registrations)
                                                {
                                                    <option value="@reg.UserId" selected="@(task.AssignedUserId == reg.UserId)">@reg.User?.Email</option>
                                                }
                                            </select>
                                        </form>
                                    </td>
                                    <td class="text-end pe-4">
                                        <form asp-action="DeleteTaskAdmin" method="post" class="m-0">
                                            <input type="hidden" name="taskId" value="@task.Id" />
                                            <input type="hidden" name="eventId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm text-danger border-0"><i class="bi bi-trash3"></i></button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card shadow-sm border-0" style="border-radius: 15px;">
                <div class="card-header bg-white fw-bold py-3">Volunteer Roster & Certificates</div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var reg in Model.Registrations)
                        {
                            <div class="p-2 border rounded-3 bg-light d-flex align-items-center">
                                <span class="@(reg.IsCheckedIn ? "text-success" : "text-muted") fw-bold me-2">
                                    <i class="bi @(reg.IsCheckedIn ? "bi-check-circle-fill" : "bi-circle")"></i>
                                    @reg.User?.Email?.Split('@')[0]
                                </span>
                                @if (reg.IsCheckedIn && Model.IsCompleted)
                                {
                                    <a asp-action="DownloadCertificateAdmin" asp-route-eventId="@Model.Id" asp-route-userId="@reg.UserId" class="btn btn-sm btn-link p-0 text-primary ms-2" title="Print Certificate">
                                        <i class="bi bi-patch-check-fill"></i>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
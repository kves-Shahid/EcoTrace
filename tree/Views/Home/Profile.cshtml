@model IEnumerable<EcoTraceApp.Models.EventRegistration>
@{
    ViewData["Title"] = "My Eco-Profile";
    int score = ViewBag.EcoScore;
    string rank = score > 1000 ? "Eco-Warrior" : (score > 500 ? "Nature Guardian" : "Seedling");
    string rankColor = score > 1000 ? "text-danger" : (score > 500 ? "text-primary" : "text-success");
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 text-center mb-4" style="border-radius: 20px; background: linear-gradient(135deg, #198754, #146c43); color: white;">
                <div class="bg-white text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow" style="width: 80px; height: 80px; font-size: 2rem; font-weight: bold;">
                    @User.Identity.Name.Substring(0, 1).ToUpper()
                </div>
                <h4 class="fw-bold">@User.Identity.Name.Split('@')[0]</h4>
                <p class="badge bg-white text-dark rounded-pill px-3">@rank</p>
                <hr class="opacity-25" />
                <h1 class="display-4 fw-bold">@score</h1>
                <p class="small text-uppercase fw-bold opacity-75">Total Eco-Points</p>
            </div>

            <div class="card border-0 shadow-sm p-3 mb-4" style="border-radius: 15px;">
                <h6 class="fw-bold text-muted mb-3">Impact Breakdown</h6>
                <div class="d-flex justify-content-between mb-2"><span>Missions Joined</span> <strong>@ViewBag.MissionsJoined</strong></div>
                <div class="d-flex justify-content-between mb-2"><span>Check-ins</span> <strong>@ViewBag.CheckIns</strong></div>
                <div class="d-flex justify-content-between"><span>Tasks Completed</span> <strong>@ViewBag.CompletedTasks</strong></div>
            </div>
        </div>

        <div class="col-lg-8">
            <h3 class="fw-bold mb-4">My Journey</h3>
            @foreach (var reg in Model)
            {
                <div class="card border-0 shadow-sm mb-3" style="border-radius: 15px;">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="fw-bold mb-1">@reg.Event.Title</h6>
                            <p class="text-muted small mb-0">@reg.Event.EventDate.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div>
                            @if (reg.IsCheckedIn)
                            {
                                <span class="badge bg-success-subtle text-success border border-success px-3 py-2 rounded-pill"><i class="bi bi-check-circle-fill me-1"></i> Completed</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-muted px-3 py-2 rounded-pill">Upcoming</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
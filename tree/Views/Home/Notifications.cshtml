@using EcoTraceApp.Models
@model IEnumerable<EcoTraceApp.Models.Notification>

@{
    ViewData["Title"] = "My Alerts";
}

<div class="container mt-5 mb-5" style="max-width: 800px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Notifications</h2>
            <p class="text-muted">Stay updated on your missions and rewards.</p>
        </div>
        <span class="badge bg-light text-dark border p-2 px-3 rounded-pill">@Model.Count() Total</span>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm p-5 text-center" style="border-radius: 20px;">
            <div class="mb-4">
                <i class="bi bi-bell-slash display-1 text-muted opacity-25"></i>
            </div>
            <h4 class="fw-bold text-muted">All quiet for now!</h4>
            <p class="text-muted">We'll notify you when an admin assigns you a task or when you earn new points.</p>
            <div class="mt-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-success rounded-pill px-4">Browse Missions</a>
            </div>
        </div>
    }
    else
    {
        <div class="shadow-sm rounded-4 overflow-hidden">
            @foreach (var notif in Model)
            {
                string icon = "bi-info-circle";
                string colorClass = "text-primary";
                string bgClass = "bg-primary-subtle";

                if (notif.Type == NotificationType.Achievement)
                {
                    icon = "bi-trophy"; colorClass = "text-warning"; bgClass = "bg-warning-subtle";
                }
                else if (notif.Type == NotificationType.TaskAssignment)
                {
                    icon = "bi-clipboard-check"; colorClass = "text-info"; bgClass = "bg-info-subtle";
                }
                else if (notif.Type == NotificationType.TaskVerification)
                {
                    icon = "bi-patch-check"; colorClass = "text-success"; bgClass = "bg-success-subtle";
                }
                else if (notif.Type == NotificationType.Announcement)
                {
                    icon = "bi-megaphone"; colorClass = "text-danger"; bgClass = "bg-danger-subtle";
                }

                <a href="@notif.LinkUrl" class="text-decoration-none">
                    <div class="d-flex align-items-start p-4 bg-white border-bottom notification-item @(notif.IsRead ? "opacity-75" : "border-start border-4 border-success")">
                        <div class="@bgClass @colorClass rounded-circle d-flex align-items-center justify-content-center me-3"
                             style="width: 50px; height: 50px; flex-shrink: 0;">
                            <i class="bi @icon fs-4"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between mb-1">
                                <h6 class="fw-bold text-dark mb-0">@notif.Type.ToString()</h6>
                                <small class="text-muted">@notif.CreatedAt.ToString("MMM dd, h:mm tt")</small>
                            </div>
                            <p class="text-muted mb-0 small">@notif.Message</p>
                        </div>
                        @if (!notif.IsRead)
                        {
                            <span class="badge bg-success rounded-circle p-1 ms-3" title="Unread">&nbsp;</span>
                        }
                    </div>
                </a>
            }
        </div>
    }
</div>

<style>
    .notification-item {
        transition: background 0.2s;
    }

        .notification-item:hover {
            background-color: #f8f9fa !important;
        }
</style>
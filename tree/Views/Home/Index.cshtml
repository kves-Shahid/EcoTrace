@model IEnumerable<EcoTraceApp.Models.Event>
@{
    ViewData["Title"] = "Global Mission Map";
    string searchQuery = ViewBag.SearchQuery as string;
}

<div class="container-fluid p-0 mb-5 position-relative">
    <div id="missionMap" style="height: 550px; width: 100%; z-index: 1;"></div>

    <div class="position-absolute top-0 start-50 translate-middle-x mt-4" style="z-index: 1000; width: 90%; max-width: 600px;">
        <form asp-controller="Home" asp-action="Search" method="get">
            <div class="input-group input-group-lg bg-white p-1 shadow-lg rounded-pill">
                <span class="input-group-text bg-transparent border-0 text-success ps-4"><i class="bi bi-geo-alt-fill"></i></span>
                <input type="text" name="query" value="@searchQuery" class="form-control border-0 shadow-none" placeholder="Find missions by city or type..." />
                <button class="btn btn-success px-4 fw-bold rounded-pill" type="submit">Search</button>
            </div>
        </form>
    </div>

    <div class="position-absolute bottom-0 start-0 m-4 p-3 bg-white shadow rounded-4 d-none d-md-block" style="z-index: 1000; max-width: 250px;">
        <h6 class="fw-bold text-success mb-1"><i class="bi bi-broadcast"></i> Live Action Map</h6>
        <p class="small text-muted mb-0">Discover @Model.Count() active missions currently happening across the region.</p>
    </div>
</div>

<div class="container mb-5" id="mission-board">
    <div class="row g-4 mb-5 pb-5 text-center border-bottom">
        <div class="col-md-4">
            <div class="p-4 bg-white rounded-4 shadow-sm border-0 h-100 transition-up">
                <div class="bg-success-subtle text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-person-plus-fill fs-3"></i>
                </div>
                <h5 class="fw-bold">1. Join</h5>
                <p class="text-muted small mb-0">Discover local missions near you and sign up instantly.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 bg-white rounded-4 shadow-sm border-0 h-100 transition-up">
                <div class="bg-primary-subtle text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-check2-square fs-3"></i>
                </div>
                <h5 class="fw-bold">2. Act</h5>
                <p class="text-muted small mb-0">Claim tasks and upload photo proof of your work.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 bg-white rounded-4 shadow-sm border-0 h-100 transition-up">
                <div class="bg-warning-subtle text-warning rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-trophy-fill fs-3"></i>
                </div>
                <h5 class="fw-bold">3. Earn</h5>
                <p class="text-muted small mb-0">Rank up on the leaderboard and get certified.</p>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold m-0">Mission Roster</h3>
        @if (!string.IsNullOrEmpty(searchQuery))
        {
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-pill px-3">View All</a>
        }
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-search display-1 text-muted opacity-25"></i>
                <h4 class="fw-bold text-muted mt-3">No missions found.</h4>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                double avgRating = item.Comments != null && item.Comments.Any() ? item.Comments.Average(c => c.Rating) : 0;
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 mission-card">
                        <div class="card-media-header" style="height: 180px; background-color: #f8f9fa; border-radius: 15px 15px 0 0; overflow: hidden;">
                            @if (!string.IsNullOrEmpty(item.MediaFilePath))
                            {
                                <img src="@item.MediaFilePath" class="w-100 h-100" style="object-fit: cover;" />
                            }
                            else
                            {
                                <div class="h-100 d-flex align-items-center justify-content-center text-muted"><i class="bi bi-image fs-1"></i></div>
                            }
                        </div>
                        <div class="card-body p-4 d-flex flex-column">
                            <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-bold mb-2 w-fit-content">@item.EventType</span>
                            <h5 class="card-title fw-bold text-dark mb-1">@item.Title</h5>
                            <p class="text-muted small mb-3"><i class="bi bi-geo-alt-fill text-danger"></i> @item.LocationName</p>

                            <div class="mt-auto">
                                <div class="d-flex justify-content-between mb-2">
                                    <small class="text-muted fw-bold">@item.Registrations.Count / @item.MaxVolunteers Joined</small>
                                    <small class="text-warning fw-bold"><i class="bi bi-star-fill"></i> @(avgRating > 0 ? avgRating.ToString("0.0") : "New")</small>
                                </div>
                                <a asp-controller="Home" asp-action="Details" asp-route-id="@item.Id" class="btn btn-dark w-100 fw-bold py-2 rounded-pill">View Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        
        var map = L.map('missionMap', { scrollWheelZoom: false }).setView([23.8103, 90.4125], 7);

        
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(map);

        var ecoIcon = L.icon({
            iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-2x-green.png',
            shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/0.7.7/images/marker-shadow.png',
            iconSize: [25, 41],
            iconAnchor: [12, 41],
            popupAnchor: [1, -34],
            shadowSize: [41, 41]
        });

        
        @foreach (var m in Model.Where(x => x.Latitude.HasValue && x.Longitude.HasValue))
        {
                <text>
                L.marker([@m.Latitude, @m.Longitude], { icon: ecoIcon }).addTo(map)
                    .bindPopup(`
                        <div class="p-1">
                            <h6 class="fw-bold mb-1">@m.Title</h6>
                            <p class="small text-muted mb-2">@m.LocationName</p>
                            <a href="/Home/Details/@m.Id" class="btn btn-sm btn-success text-white w-100">View Mission</a>
                        </div>
                    `);
                </text>
        }
    </script>
}

<style>
    .mission-card {
        transition: all 0.3s ease;
        border-radius: 15px;
    }

        .mission-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,0.1) !important;
        }

    .transition-up {
        transition: transform 0.3s ease;
    }

        .transition-up:hover {
            transform: translateY(-5px);
        }

    .w-fit-content {
        width: fit-content;
    }

    .hover-success:hover {
        color: #198754 !important;
    }
</style>